# Omarchy-style keybindings for macOS.
# Super = Option/Alt. Omarchy Alt combos use Command on macOS.

# Launchers
alt - return : /usr/bin/open -na Ghostty
alt + cmd - return : /Applications/Ghostty.app/Contents/MacOS/ghostty -e /opt/homebrew/bin/bash -lc 'tmux new-session -A -s main'
alt - space : /usr/bin/open -na Raycast
alt + cmd - space : /Applications/Ghostty.app/Contents/MacOS/ghostty -e "$HOME"/.local/bin/hyprmac help || /usr/bin/open -na Ghostty
alt - k : "$HOME"/.local/bin/hyprmac docs keybindings
alt - escape : "$HOME"/.config/sketchybar/plugins/power.sh toggle || "$HOME"/.local/bin/hyprmac power

alt - b : /usr/bin/open -na Safari
alt + shift - b : /usr/bin/open -na Helium
alt + shift - return : /usr/bin/open -na Safari
alt + shift - f : /usr/bin/open -na Finder
alt + shift - n : /Applications/Ghostty.app/Contents/MacOS/ghostty -e /opt/homebrew/bin/bash -lc 'nvim'
alt + shift - d : /Applications/Ghostty.app/Contents/MacOS/ghostty -e /opt/homebrew/bin/bash -lc 'lazydocker'
alt + shift - o : /usr/bin/open -na Obsidian
alt + shift - m : /usr/bin/open -na Spotify || /usr/bin/open -na Music
alt + shift - c : /usr/bin/open -na Calendar
alt + shift - e : /usr/bin/open -na Mail
alt + shift - a : /usr/bin/open -na ChatGPT
alt + shift - g : /usr/bin/open -na Signal
alt + cmd + shift - g : /usr/bin/open -na WhatsApp
alt + shift - x : /usr/bin/open -na X
alt + shift - 0x2C : /usr/bin/open -na "1Password"

# Service controls, intentionally moved away from Omarchy utility combos.
alt + ctrl + cmd - r : "$HOME"/.local/bin/hyprmac reload
alt + ctrl + cmd - y : "$HOME"/.local/bin/hyprmac yabai restart
alt + ctrl + cmd - s : "$HOME"/.local/bin/hyprmac skhd restart
alt + ctrl + cmd - b : "$HOME"/.local/bin/hyprmac bar restart

# Windows
alt - w : /bin/sh "$HOME"/.config/yabai/scripts/close-window.sh
alt - t : /opt/homebrew/bin/yabai -m window --toggle float
alt - o : /bin/sh "$HOME"/.config/yabai/scripts/pop-window.sh
alt - l : /bin/sh "$HOME"/.config/yabai/scripts/toggle-layout.sh
alt - j : /opt/homebrew/bin/yabai -m window --toggle split
alt - f : /opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen
alt + ctrl - f : /opt/homebrew/bin/yabai -m window --toggle zoom-parent
alt + cmd - f : /bin/sh "$HOME"/.config/yabai/scripts/full-width.sh

alt - left : /opt/homebrew/bin/yabai -m window --focus west
alt - down : /opt/homebrew/bin/yabai -m window --focus south
alt - up : /opt/homebrew/bin/yabai -m window --focus north
alt - right : /opt/homebrew/bin/yabai -m window --focus east

alt + shift - left : /opt/homebrew/bin/yabai -m window --swap west
alt + shift - down : /opt/homebrew/bin/yabai -m window --swap south
alt + shift - up : /opt/homebrew/bin/yabai -m window --swap north
alt + shift - right : /opt/homebrew/bin/yabai -m window --swap east

alt + cmd - left : /opt/homebrew/bin/yabai -m window --stack west
alt + cmd - down : /opt/homebrew/bin/yabai -m window --stack south
alt + cmd - up : /opt/homebrew/bin/yabai -m window --stack north
alt + cmd - right : /opt/homebrew/bin/yabai -m window --stack east

alt + ctrl + cmd - h : /opt/homebrew/bin/yabai -m window --warp west
alt + ctrl + cmd - j : /opt/homebrew/bin/yabai -m window --warp south
alt + ctrl + cmd - k : /opt/homebrew/bin/yabai -m window --warp north
alt + ctrl + cmd - l : /opt/homebrew/bin/yabai -m window --warp east

alt - g : /opt/homebrew/bin/yabai -m window --stack recent
alt + cmd - g : /opt/homebrew/bin/yabai -m window --insert east
alt + cmd - tab : /opt/homebrew/bin/yabai -m window --focus stack.next
alt + cmd + shift - tab : /opt/homebrew/bin/yabai -m window --focus stack.prev
alt + cmd - 0x12 : /opt/homebrew/bin/yabai -m window --focus stack.1
alt + cmd - 0x13 : /opt/homebrew/bin/yabai -m window --focus stack.2
alt + cmd - 0x14 : /opt/homebrew/bin/yabai -m window --focus stack.3
alt + cmd - 0x15 : /opt/homebrew/bin/yabai -m window --focus stack.4
alt + cmd - 0x17 : /opt/homebrew/bin/yabai -m window --focus stack.5

alt - s : /opt/homebrew/bin/yabai -m window --toggle hyprmac-scratchpad
alt + cmd - s : /opt/homebrew/bin/yabai -m window --scratchpad hyprmac-scratchpad

alt - 0x1B : /bin/sh "$HOME"/.config/yabai/scripts/resize-window.sh width shrink
alt - 0x18 : /bin/sh "$HOME"/.config/yabai/scripts/resize-window.sh width grow
alt + shift - 0x1B : /bin/sh "$HOME"/.config/yabai/scripts/resize-window.sh height shrink
alt + shift - 0x18 : /bin/sh "$HOME"/.config/yabai/scripts/resize-window.sh height grow

# Clipboard, adapted from Omarchy universal clipboard bindings to macOS commands.
alt - c : /usr/bin/osascript -e 'tell application "System Events" to keystroke "c" using command down'
alt - x : /usr/bin/osascript -e 'tell application "System Events" to keystroke "x" using command down'
alt - v : /usr/bin/osascript -e 'tell application "System Events" to keystroke "v" using command down'
alt + ctrl - v : /usr/bin/open 'raycast://extensions/raycast/clipboard-history/clipboard-history'
alt + ctrl - e : /usr/bin/osascript -e 'tell application "System Events" to keystroke space using {control down, command down}'

# Workspaces
alt - 0x12 : /opt/homebrew/bin/yabai -m space --focus ws1
alt - 0x13 : /opt/homebrew/bin/yabai -m space --focus ws2
alt - 0x14 : /opt/homebrew/bin/yabai -m space --focus ws3
alt - 0x15 : /opt/homebrew/bin/yabai -m space --focus ws4
alt - 0x17 : /opt/homebrew/bin/yabai -m space --focus ws5
alt - 0x16 : /opt/homebrew/bin/yabai -m space --focus ws6
alt - 0x1A : /opt/homebrew/bin/yabai -m space --focus ws7
alt - 0x1C : /opt/homebrew/bin/yabai -m space --focus ws8
alt - 0x19 : /opt/homebrew/bin/yabai -m space --focus ws9
alt - 0x1D : /opt/homebrew/bin/yabai -m space --focus ws10

alt + shift - 0x12 : /opt/homebrew/bin/yabai -m window --space ws1 && /opt/homebrew/bin/yabai -m space --focus ws1
alt + shift - 0x13 : /opt/homebrew/bin/yabai -m window --space ws2 && /opt/homebrew/bin/yabai -m space --focus ws2
alt + shift - 0x14 : /opt/homebrew/bin/yabai -m window --space ws3 && /opt/homebrew/bin/yabai -m space --focus ws3
alt + shift - 0x15 : /opt/homebrew/bin/yabai -m window --space ws4 && /opt/homebrew/bin/yabai -m space --focus ws4
alt + shift - 0x17 : /opt/homebrew/bin/yabai -m window --space ws5 && /opt/homebrew/bin/yabai -m space --focus ws5
alt + shift - 0x16 : /opt/homebrew/bin/yabai -m window --space ws6 && /opt/homebrew/bin/yabai -m space --focus ws6
alt + shift - 0x1A : /opt/homebrew/bin/yabai -m window --space ws7 && /opt/homebrew/bin/yabai -m space --focus ws7
alt + shift - 0x1C : /opt/homebrew/bin/yabai -m window --space ws8 && /opt/homebrew/bin/yabai -m space --focus ws8
alt + shift - 0x19 : /opt/homebrew/bin/yabai -m window --space ws9 && /opt/homebrew/bin/yabai -m space --focus ws9
alt + shift - 0x1D : /opt/homebrew/bin/yabai -m window --space ws10 && /opt/homebrew/bin/yabai -m space --focus ws10

alt + cmd + shift - 0x12 : /opt/homebrew/bin/yabai -m window --space ws1
alt + cmd + shift - 0x13 : /opt/homebrew/bin/yabai -m window --space ws2
alt + cmd + shift - 0x14 : /opt/homebrew/bin/yabai -m window --space ws3
alt + cmd + shift - 0x15 : /opt/homebrew/bin/yabai -m window --space ws4
alt + cmd + shift - 0x17 : /opt/homebrew/bin/yabai -m window --space ws5
alt + cmd + shift - 0x16 : /opt/homebrew/bin/yabai -m window --space ws6
alt + cmd + shift - 0x1A : /opt/homebrew/bin/yabai -m window --space ws7
alt + cmd + shift - 0x1C : /opt/homebrew/bin/yabai -m window --space ws8
alt + cmd + shift - 0x19 : /opt/homebrew/bin/yabai -m window --space ws9
alt + cmd + shift - 0x1D : /opt/homebrew/bin/yabai -m window --space ws10

alt - tab : /opt/homebrew/bin/yabai -m space --focus next || /opt/homebrew/bin/yabai -m space --focus first
alt + shift - tab : /opt/homebrew/bin/yabai -m space --focus prev || /opt/homebrew/bin/yabai -m space --focus last
alt + ctrl - tab : /opt/homebrew/bin/yabai -m space --focus recent

alt + cmd + shift - left : /opt/homebrew/bin/yabai -m space --display prev
alt + cmd + shift - right : /opt/homebrew/bin/yabai -m space --display next
alt + cmd + shift - up : /opt/homebrew/bin/yabai -m space --display prev
alt + cmd + shift - down : /opt/homebrew/bin/yabai -m space --display next

# System and utilities
alt + ctrl - a : "$HOME"/.config/sketchybar/plugins/volume.sh toggle || /usr/bin/open 'x-apple.systempreferences:com.apple.Sound-Settings.extension'
alt + ctrl - b : "$HOME"/.config/sketchybar/plugins/bluetooth.sh toggle || /usr/bin/open 'x-apple.systempreferences:com.apple.BluetoothSettings'
alt + ctrl - w : "$HOME"/.config/sketchybar/plugins/wifi.sh toggle || /usr/bin/open 'x-apple.systempreferences:com.apple.WiFi-Settings.extension'
alt + ctrl - t : /usr/bin/open -na "Activity Monitor"
alt + ctrl - c : /usr/bin/open -a Screenshot
alt + ctrl - space : /usr/bin/open -na Raycast
alt + ctrl + shift - space : /usr/bin/open -na Raycast
alt + ctrl - l : /System/Library/CoreServices/Menu\ Extras/User.menu/Contents/Resources/CGSession -suspend

alt + shift - space : "$HOME"/.local/bin/hyprmac bar toggle
alt + shift - 0x33 : /opt/homebrew/bin/yabai -m space --toggle gap
alt + ctrl - 0x33 : /opt/homebrew/bin/yabai -m space --toggle padding

# Local display navigation that does not conflict with Omarchy swap bindings.
alt + ctrl + cmd - left : /opt/homebrew/bin/yabai -m display --focus prev
alt + ctrl + cmd - right : /opt/homebrew/bin/yabai -m display --focus next
alt + ctrl + cmd + shift - left : /opt/homebrew/bin/yabai -m window --display prev && /opt/homebrew/bin/yabai -m display --focus prev
alt + ctrl + cmd + shift - right : /opt/homebrew/bin/yabai -m window --display next && /opt/homebrew/bin/yabai -m display --focus next

.load "skhdrc.local"
